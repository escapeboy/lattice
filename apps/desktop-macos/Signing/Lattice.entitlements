<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- bun (the backend) and Chromium use JIT; hardened runtime blocks it
         without these. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- The app spawns the embedded backend binary, which is signed separately;
         allow loading it without strict library validation. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Local gateway/control-plane server + outbound (egress proxy / Chromium). -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- NOTE: vault-key persistence in the data-protection keychain would use a
         `keychain-access-groups` entitlement (Team UQK5BS5U9A) — but that is a
         RESTRICTED entitlement: it requires an embedded provisioning profile, and
         without one the signed app fails to launch (launchd error 163). Until a
         provisioning profile for net.lattice.desktop is created (Apple Developer
         portal), the vault stays ephemeral. Do NOT re-add this without the profile. -->
</dict>
</plist>

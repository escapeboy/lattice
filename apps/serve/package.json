{
  "name": "@lattice/serve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "lattice-serve": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "serve": "node dist/main.js"
  },
  "dependencies": {
    "@lattice/control-plane": "workspace:*",
    "@lattice/engine": "workspace:*",
    "@lattice/gateway": "workspace:*",
    "@lattice/kernel": "workspace:*",
    "@lattice/observability": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

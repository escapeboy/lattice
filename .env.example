# Lattice — example environment configuration.
# Copy to `.env` and fill in real values. NEVER commit a populated `.env`.
# All values below are placeholders, not real secrets.

# --- Network / ports ---
LATTICE_PORT=8765                 # gateway MCP port
LATTICE_HOST=0.0.0.0              # gateway bind host
CONTROL_PLANE_PORT=7900           # control-plane UI port
CONTROL_PLANE_HOST=127.0.0.1      # control-plane bind host
LATTICE_TRANSPORT=http            # "http" (default) or "stdio"

# --- Auth tokens (auto-generated per run if unset; set to pin them) ---
LATTICE_MCP_TOKEN=                # bearer token for the agent-facing MCP gateway
LATTICE_CP_TOKEN=                 # bearer token for the operator control-plane UI

# --- Engine ---
LATTICE_ENGINE=                   # default = governed build-on stack; "cdp" = legacy raw-CDP (dev only)
CHROME_EXECUTABLE=                # path to Chromium (auto-detected if unset)
LATTICE_HEADED=                   # "1" to run the browser headed
LATTICE_DEVICE=                   # optional device profile name

# --- Governance / safety ---
LATTICE_ALLOWED_ORIGINS=          # comma-separated origin allowlist (empty = dev-unrestricted)
LATTICE_EGRESS_ALLOWLIST=         # comma-separated egress firewall allowlist
LATTICE_PROHIBITED=               # comma-separated prohibited-tier markers
LATTICE_PII_FULL_ORIGINS=         # origins logged in full (default: all redacted)

# --- Handoff (human-in-the-loop push) ---
LATTICE_NTFY_BASE=                # ntfy base URL for handoff push notifications
LATTICE_HANDOFF_KEY=              # signing key for handoff links

# --- Vault (secret storage) ---
LATTICE_VAULT_KEY=                # vault encryption key (placeholder — use a real key locally)
LATTICE_VAULT_PATH=               # vault persistence path

# --- Trace sink ---
LATTICE_TRACE_DIR=./traces        # directory for Svod trace notes (gitignored)
